# ── 10bis ────────────────────────────────────────────────────────────────────

# Your 10bis login email
TENBIS_EMAIL=you@example.com

# The Shufersal dish URL from the 10bis restaurant page
TENBIS_ITEM_URL=https://www.10bis.co.il/next/en/restaurants/menu/delivery/26698/shufersal/?dishId=6552647

# Voucher price in ILS (also the minimum budget threshold)
TENBIS_ITEM_PRICE=200

# Minimum monthly and daily balance required before purchasing
TENBIS_MIN_MONTHLY_BALANCE=200
TENBIS_MIN_DAILY_BALANCE=200

# ── WhatsApp ──────────────────────────────────────────────────────────────────

# Exact title of the WhatsApp group to send vouchers to
WHATSAPP_GROUP_NAME=Vouchers

# ── paths ─────────────────────────────────────────────────────────────────────

# Root for all runtime data (profiles, vouchers, debug dumps)
# Defaults to ./data relative to the repo. Override on the server if needed.
# DATA_DIR=/home/youruser/tenbis/data

# ── runtime ───────────────────────────────────────────────────────────────────

# Run Playwright headless (true on server, false for local login sessions)
HEADLESS=true

# When true, go through the full purchase flow but skip the final Submit click
DRY_RUN=false

# Set to true for verbose structlog output
DEBUG=false

# Timezone for date-stamping voucher filenames and log entries
TIMEZONE=Asia/Jerusalem

# ── deploy (laptop only) ──────────────────────────────────────────────────────

# SSH target for `mise run deploy` and `mise run sync:profiles`
# SERVER=user@your-server-hostname
